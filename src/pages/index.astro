---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Melody Seed Generator">
  <main class="home-hero">
    <h1>Melody Seed Generator</h1>
    <p>
      Процедурный генератор монофонических MIDI-мелодий для загрузки в AI-музыкальные сервисы.
      Создавайте seed, добавляйте аккорды и бас, экспортируйте MIDI, WAV или project file.
    </p>
    <div class="cta-row">
      <a href="/generator" class="button-link primary">Открыть генератор</a>
    </div>
  </main>
</BaseLayout>
